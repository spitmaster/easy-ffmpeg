# Binaries
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace file
go.work

# Go vendor
vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build output
/bin/
/dist/
build/

# Environment
.env
.env.local

# Wails desktop build artifacts (cmd/desktop/build/ already matched by
# the generic build/ rule above; listed here for discoverability).
# Note: cmd/desktop/frontend/dist/index.html IS committed — it is the
# static shell loaded by Wails AssetServer, not a build product.
cmd/desktop/build/bin/
cmd/desktop/wailsjs/
cmd/desktop/frontend/wailsjs/

# Frontend (Vue 3) — sources live in web/src, build output goes to web/dist.
# .gitkeep is committed so //go:embed all:dist in web/embed.go succeeds on
# fresh clones before npm run build has populated the directory.
web/node_modules/
web/dist/*
!web/dist/.gitkeep
